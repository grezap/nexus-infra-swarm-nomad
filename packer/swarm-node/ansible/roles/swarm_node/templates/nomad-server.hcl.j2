# nomad-server.hcl.tpl -- rendered by swarm-node-firstboot.sh on managers
# (swarm-manager-1/2/3). Replaceable @MARKERS@:
#   @HOSTNAME@      e.g. swarm-manager-1
#   @VMNET11_IP@    e.g. 192.168.70.111
#   @VMNET10_IP@    e.g. 192.168.10.111  (Nomad raft + serf bind here)

datacenter = "nexus-lab"
data_dir   = "/opt/nomad/data"
name       = "@HOSTNAME@"
log_level  = "INFO"

bind_addr = "@VMNET10_IP@"

# Override the HTTP bind specifically so `nomad server members` works from
# localhost (and from the operator's VMnet11 build host) without setting
# NOMAD_ADDR. raft (4647) + serf (4648) stay bound to VMnet10 only -- nftables
# blocks them on other paths anyway, but defense-in-depth at the bind layer.
# 0.0.0.0 here is safe because nftables on nic0 only opens 4646 from VMnet11.
addresses {
  http = "0.0.0.0"
}

advertise {
  http = "@VMNET10_IP@:4646"
  rpc  = "@VMNET10_IP@:4647"
  serf = "@VMNET10_IP@:4648"
}

server {
  enabled          = true
  bootstrap_expect = 3
}

# Co-located Consul agent on this node provides service discovery + auto-join
consul {
  address = "127.0.0.1:8500"
}

# UI on the management interface (VMnet11) for operator access
ports {
  http = 4646
  rpc  = 4647
  serf = 4648
}

# ACLs / TLS deferred to 0.E.5 (Vault PKI integration)
